# LiteLLM proxy URL (default: http://localhost:4000)
LITELLM_BASE_URL=http://localhost:4000

# LiteLLM API key
LITELLM_API_KEY=sk-your-litellm-key

# Model to use through LiteLLM (e.g. anthropic/claude-sonnet-4-6, gpt-4o)
LITELLM_MODEL=anthropic/claude-sonnet-4-6

# SerpAPI key for web search (get free key at https://serpapi.com)
SERPAPI_KEY=your-serpapi-key

# Anthropic API key — passed to the LiteLLM proxy so it can call Claude
ANTHROPIC_API_KEY=sk-ant-api03-...